# BusBook local development environment
APP_NAME=BusBook
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://busbook:busbook_secret@localhost:5432/busbook
DATABASE_SYNC_URL=postgresql+psycopg2://busbook:busbook_secret@localhost:5432/busbook

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-production-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]

# Razorpay (Test credentials — replace with your test keys)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret

# Seat Lock
SEAT_LOCK_TTL_SECONDS=300

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Admin Seed
ADMIN_EMAIL=admin@busbook.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Admin
