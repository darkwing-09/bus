{
  "name": "busbook-frontend",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:user": "npm run dev --workspace=apps/user",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:conductor": "npm run dev --workspace=apps/conductor",
    "build:user": "npm run build --workspace=apps/user",
    "build:admin": "npm run build --workspace=apps/admin",
    "build:conductor": "npm run build --workspace=apps/conductor",
    "dev": "concurrently \"npm run dev:user\" \"npm run dev:admin\" \"npm run dev:conductor\"",
    "build": "npm run build:user && npm run build:admin && npm run build:conductor",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
